    "tailwindcss-animated": "^1.0.1",
    "typescript": "4.9.5"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.10",
    "autoprefixer": "^10.4.13",
    "download": "^8.0.0",
    "md-to-pdf": "^5.2.4",
    "postcss": "^8.4.21",
