{
  "name": "andrewvos.com",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun --watch src/server.tsx",
    "build": "bun run build:css && bun run build:client",
    "build:client": "bun build ./src/client.tsx --outdir=public/build --target=browser --minify",
    "build:cv": "bun src/build-cv.ts",
    "build:css": "tailwindcss -i ./app/globals.css -o ./public/build/styles.css --minify",
    "build:static": "bun src/static.tsx",
    "check": "tsc --noEmit",
    "lint": "bun run check",
    "start": "bun src/server.tsx",
    "test": "bun run check && bun run build && bun run build:cv && bun run build:static && bun test",
    "vercel-build": "bun run build && bun run build:cv && bun run build:static",
    "scrape-book": "bun scripts/scrape-book.mjs",
    "renew-book-thumbnails": "bun scripts/renew-book-thumbnails.mjs"
  },
  "dependencies": {
    "@types/react": "18.0.28",
    "@types/react-dom": "18.0.11",
    "classnames": "^2.3.2",
    "date-fns": "^3.3.1",
    "image-size": "^1.1.1",
    "inquirer": "^9.3.8",
    "prompts": "^2.4.2",
    "query-string": "^8.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss-animated": "^1.0.1",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.10",
    "@types/bun": "^1.3.0",
    "@types/node": "^20.11.17",
    "@types/pdfkit": "^0.17.6",
    "autoprefixer": "^10.4.13",
    "download": "^8.0.0",
    "pdfkit": "^0.18.0",
    "playwright": "^1.59.1",
    "postcss": "^8.4.21",
    "puppeteer": "^22.1.0",
    "slug": "^8.2.2",
    "tailwindcss": "^3.2.6"
  }
}
